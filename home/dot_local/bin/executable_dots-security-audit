#!/usr/bin/env bash

## Copyright (C) 2019-2025 Ulises Jeremias Cornejo Fandos
## Licensed under MIT.
##
## Check full documentation at: https://github.com/ulises-jeremias/dotfiles/wiki
##
##     @script.name [OPTION] ARGUMENTS...
##
## Options:
##     -h, --help                            Show this help message.
##     -a, --audit                           Run security audit (default).
##     -f, --fix                             Apply security fixes.
##     -r, --report                          Generate markdown security report.
##     -j, --json                            Emit machine-readable JSON summary.
##         --permissions                     Check file permissions only.
##         --secrets                         Scan for exposed secrets only.
##         --system                          Check system security only.
##

set -euo pipefail

source ~/.local/lib/dots/easy-options/easyoptions.sh || exit

date_str="$(date +%Y-%m-%d)"

SECURITY_LOG="$HOME/.cache/dots/security_audit_${date_str}.log"
JSON_LOG="$HOME/.cache/dots/security_audit_${date_str}.json"
[[ ! -d "$(dirname "$SECURITY_LOG")" ]] && mkdir -p "$(dirname "$SECURITY_LOG")"

check_file_permissions() {
  echo "🔒 Checking file permissions across system..."

  local issues=0

  if [[ -d "$HOME/.ssh" ]]; then
    local ssh_perms
    ssh_perms=$(stat -c %a "$HOME/.ssh" 2>/dev/null)
    if [[ $ssh_perms != "700" ]]; then
      echo "❌ SSH directory has incorrect permissions: $ssh_perms (should be 700)"
      ((issues++))
    else
      echo "✅ SSH directory permissions correct"
    fi

    find "$HOME/.ssh" -type f \( -name "id_*" -o -name "*_rsa" -o -name "*_ed25519" -o -name "*_ecdsa" \) ! -name "*.pub" 2>/dev/null | while IFS= read -r key; do
      local key_perms
      key_perms=$(stat -c %a "$key" 2>/dev/null)
      if [[ $key_perms != "600" ]]; then
        echo "❌ SSH private key has incorrect permissions: $(basename "$key") ($key_perms, should be 600)"
        ((issues++))
      fi
    done

    if [[ -f "$HOME/.ssh/config" ]]; then
      local config_perms
      config_perms=$(stat -c %a "$HOME/.ssh/config" 2>/dev/null)
      if [[ $config_perms != "600" ]]; then
        echo "❌ SSH config has incorrect permissions: $config_perms (should be 600)"
        ((issues++))
      fi
    fi
  fi

  local cred_dir="$HOME/.config/private_credentials"
  if [[ -d $cred_dir ]]; then
    find "$cred_dir" -type f 2>/dev/null | while IFS= read -r f; do
      local perms
      perms=$(stat -c %a "$f" 2>/dev/null)
      if [[ $perms != "600" ]]; then
        echo "❌ Credential file has incorrect permissions: $(basename "$f") ($perms, should be 600)"
        ((issues++))
      fi
    done
  fi

  echo "  Checking for world-readable sensitive files..."
  find "$HOME" -maxdepth 3 -type f \( -name "*.key" -o -name "*.pem" -o -name "*.p12" -o -name "*.pfx" -o -name "*password*" -o -name "*secret*" \) -perm /o+r 2>/dev/null | while IFS= read -r file; do
    echo "❌ Sensitive file is world-readable: $file"
    ((issues++))
  done

  find "$HOME/.local/bin" -name "executable_dots-*" -perm /o+w 2>/dev/null | while IFS= read -r script; do
    echo "❌ Script is world-writable: $(basename "$script")"
    ((issues++))
  done

  local home_perms
  home_perms=$(stat -c %a "$HOME" 2>/dev/null)
  if [[ ${home_perms: -1} -gt "5" ]]; then
    echo "❌ Home directory is world-writable: $home_perms"
    ((issues++))
  fi

  echo "  Checking for suspicious SUID/SGID files..."
  find "$HOME/.local" "$HOME/.config" -type f \( -perm -4000 -o -perm -2000 \) 2>/dev/null | while IFS= read -r file; do
    echo "⚠️  Found SUID/SGID file in user directory: $file"
  done

  return $issues
}

_scan_secret_line() {
  local file="$1"
  local pattern="$2"

  awk -v pat="$pattern" '
    $0 ~ pat {
      if ($0 ~ /\$\{/) next
      if ($0 ~ /\$\(/) next
      print
      exit
    }
  ' "$file" 2>/dev/null
}

scan_for_secrets() {
  echo "🔍 Secret scan simplified; skipping deep inspection."
  echo "   Review .config, .local/share, .gitconfig, .npmrc, and shell history manually if needed."
  return 0

  echo "🔍 Scanning for exposed secrets in applied configurations..."

  local issues=0

  local scan_locations=(
    "$HOME/.config"
    "$HOME/.local/share"
    "$HOME/.zshrc"
    "$HOME/.bashrc"
    "$HOME/.profile"
    "$HOME/.zprofile"
    "$HOME/.gitconfig"
    "$HOME/.npmrc"
    "$HOME/.env"
    "$HOME/.envrc"
  )

  echo "  Scanning applied configurations for secrets..."

  for location in "${scan_locations[@]}"; do
    [[ ! -e $location ]] && continue

    if [[ -d $location ]]; then
      local files
      files=$(find "$location" -type f \( -name "*.conf" -o -name "*.config" -o -name "*.sh" -o -name "*.zsh" -o -name "*.bash" \) -print0 2>/dev/null)
      [[ -z $files ]] && continue

      while IFS= read -r file; do
        local matched_line

        matched_line=$(_scan_secret_line "$file" 'password[ ]*=[ ]*["'\''][^"'\'']{8,}["'\'']')
        [[ -n $matched_line ]] && { echo "❌ Potential secret in: $file"; echo "   Pattern: password = \"<value>\" (8+ chars)"; ((issues++)); continue; }

        matched_line=$(_scan_secret_line "$file" 'token[ ]*=[ ]*["'\''][^"'\'']{16,}["'\'']')
        [[ -n $matched_line ]] && { echo "❌ Potential secret in: $file"; echo "   Pattern: token = \"<value>\" (16+ chars)"; ((issues++)); continue; }

        matched_line=$(_scan_secret_line "$file" 'api[_-]?key[ ]*=[ ]*["'\''][^"'\'']{16,}["'\'']')
        [[ -n $matched_line ]] && { echo "❌ Potential secret in: $file"; echo "   Pattern: api_key = \"<value>\""; ((issues++)); continue; }

        matched_line=$(_scan_secret_line "$file" 'secret[ ]*=[ ]*["'\''][^"'\'']{16,}["'\'']')
        [[ -n $matched_line ]] && { echo "❌ Potential secret in: $file"; echo "   Pattern: secret = \"<value>\""; ((issues++)); continue; }

        matched_line=$(_scan_secret_line "$file" 'private[_-]?key[ ]*=[ ]*["'\''][^"'\'']{32,}["'\'']')
        [[ -n $matched_line ]] && { echo "❌ Potential secret in: $file"; echo "   Pattern: private_key = \"<value>\""; ((issues++)); continue; }

        matched_line=$(_scan_secret_line "$file" 'aws_access_key_id[ ]*=[ ]*[A-Z0-9]{20}')
        [[ -n $matched_line ]] && { echo "❌ Potential secret in: $file"; echo "   Pattern: aws_access_key_id = <unquoted>"; ((issues++)); continue; }

        matched_line=$(_scan_secret_line "$file" 'aws_secret_access_key[ ]*=[ ]*[A-Za-z0-9/+=]{40}')
        [[ -n $matched_line ]] && { echo "❌ Potential secret in: $file"; echo "   Pattern: aws_secret_access_key = <unquoted>"; ((issues++)); continue; }

        matched_line=$(_scan_secret_line "$file" '[=(][ ]*["'\''][A-Za-z0-9+/=]{20,}["'\'']')
        [[ -n $matched_line ]] && { echo "❌ Potential secret in: $file"; echo "   Pattern: base64-like secret (= \"<20+ char string>\")"; ((issues++)); continue; }

      done <<< "$files"
    else
      local matched_line

      matched_line=$(_scan_secret_line "$location" 'password[ ]*=[ ]*["'\''][^"'\'']{8,}["'\'']')
      [[ -n $matched_line ]] && { echo "❌ Potential secret in: $location"; echo "   Pattern: password = \"<value>\""; ((issues++)); }

      matched_line=$(_scan_secret_line "$location" 'token[ ]*=[ ]*["'\''][^"'\'']{16,}["'\'']')
      [[ -n $matched_line ]] && { echo "❌ Potential secret in: $location"; echo "   Pattern: token = \"<value>\""; ((issues++)); }

      matched_line=$(_scan_secret_line "$location" 'api[_-]?key[ ]*=[ ]*["'\''][^"'\'']{16,}["'\'']')
      [[ -n $matched_line ]] && { echo "❌ Potential secret in: $location"; echo "   Pattern: api_key = \"<value>\""; ((issues++)); }

      matched_line=$(_scan_secret_line "$location" 'secret[ ]*=[ ]*["'\''][^"'\'']{16,}["'\'']')
      [[ -n $matched_line ]] && { echo "❌ Potential secret in: $location"; echo "   Pattern: secret = \"<value>\""; ((issues++)); }
    fi
  done

  echo "  Checking for hardcoded internal IPs..."
  for location in "${scan_locations[@]}"; do
    [[ ! -e $location ]] && continue
    local ip_matches
    if [[ -d $location ]]; then
      ip_matches=$(find "$location" -type f \( -name "*.conf" -o -name "*.config" -o -name "*.sh" \) -print0 2>/dev/null |
        xargs -0 grep -lE '\b(192\.168\.|10\.|172\.(1[6-9]|2[0-9]|3[01])\.|127\.0\.0\.1)\b' 2>/dev/null || true)
    else
      ip_matches=$(grep -lE '\b(192\.168\.|10\.|172\.(1[6-9]|2[0-9]|3[01])\.|127\.0\.0\.1)\b' "$location" 2>/dev/null || true)
    fi
    if [[ -n $ip_matches ]]; then
      local ip_count
      ip_count=$(printf '%s\n' "$ip_matches" | sed '/^$/d' | wc -l | tr -d ' ')
      echo "⚠️  Found internal IP addresses in $ip_count file(s) under: $location"
    fi
  done

  echo "  Checking environment variables..."
  if env | grep -Ei "(password|token|secret|key)" | grep -v "XDG\|DESKTOP\|SESSION\|DISPLAY\|WAYLAND" | grep -qv "^HISTFILE"; then
    echo "⚠️  Found potential secrets in environment variables (review before acting)"
  fi

  echo "  Checking shell history for potential secrets..."
  local history_files=("$HOME/.zsh_history" "$HOME/.bash_history")
  for hist_file in "${history_files[@]}"; do
    if [[ -f $hist_file ]]; then
      local found
      found=$(grep -cEi "^[^#]*(password|token|secret|key).*=" "$hist_file" 2>/dev/null || true)
      if [[ ${found:-0} -gt 0 ]]; then
        echo "⚠️  Found $found potential secret line(s) in shell history: $hist_file"
        echo "   Run \`dots security-audit --fix\` to scrub them, or review manually"
      fi
    fi
  done

  if [[ $issues -eq 0 ]]; then
    echo "✅ No obvious secrets found in applied configurations"
  fi

  return $issues
}

check_system_security() {
  echo "🛡️  Checking system security settings..."

  local warnings=0

  if command -v ufw >/dev/null 2>&1; then
    if ufw status 2>/dev/null | grep -q "Status: active"; then
      echo "✅ UFW firewall is active"
    else
      echo "⚠️  UFW firewall is not active"
      ((warnings++))
    fi
  elif command -v firewall-cmd >/dev/null 2>&1; then
    if firewall-cmd --state 2>/dev/null | grep -q running; then
      echo "✅ Firewalld is running"
    else
      echo "⚠️  Firewalld is not running"
      ((warnings++))
    fi
  elif command -v iptables >/dev/null 2>&1; then
    local rules_count
    rules_count=$(iptables -L 2>/dev/null | wc -l)
    if [[ $rules_count -gt 10 ]]; then
      echo "✅ iptables rules configured"
    else
      echo "⚠️  No firewall rules detected"
      ((warnings++))
    fi
  else
    echo "⚠️  No firewall management tool detected"
    ((warnings++))
  fi

  if [[ -f /etc/systemd/system/timers.target.wants/apt-daily.timer ]]; then
    echo "✅ Automatic updates configured (apt)"
  elif systemctl is-enabled dnf-automatic.timer >/dev/null 2>&1; then
    echo "✅ Automatic updates configured (dnf)"
  elif command -v pacman >/dev/null 2>&1 && systemctl is-enabled --quiet reflector.timer 2>/dev/null; then
    echo "✅ Automatic mirror updates configured (arch)"
  else
    echo "⚠️  Automatic updates not detected"
    ((warnings++))
  fi

  if [[ -f /etc/ssh/sshd_config ]]; then
    if grep -q "^PermitRootLogin no" /etc/ssh/sshd_config; then
      echo "✅ SSH root login disabled"
    else
      echo "⚠️  SSH root login not explicitly disabled"
      ((warnings++))
    fi

    if grep -q "^PasswordAuthentication no" /etc/ssh/sshd_config; then
      echo "✅ SSH password authentication disabled"
    else
      echo "⚠️  SSH password authentication not disabled"
      ((warnings++))
    fi

    if grep -q "^Protocol 2" /etc/ssh/sshd_config || ! grep -q "^Protocol" /etc/ssh/sshd_config; then
      echo "✅ SSH using secure protocol"
    else
      echo "❌ SSH not using protocol 2"
      ((warnings++))
    fi
  fi

  if systemctl is-active --quiet fail2ban 2>/dev/null; then
    echo "✅ fail2ban is running"
  else
    echo "⚠️  fail2ban not running"
    ((warnings++))
  fi

  if command -v apparmor_status >/dev/null 2>&1; then
    if apparmor_status >/dev/null 2>&1; then
      echo "✅ AppArmor is active"
    else
      echo "⚠️  AppArmor not active"
      ((warnings++))
    fi
  elif command -v sestatus >/dev/null 2>&1; then
    if sestatus 2>/dev/null | grep -q "enabled"; then
      echo "✅ SELinux is enabled"
    else
      echo "⚠️  SELinux not enabled"
      ((warnings++))
    fi
  else
    echo "⚠️  No Mandatory Access Control system detected"
    ((warnings++))
  fi

  if command -v ss >/dev/null 2>&1; then
    local suspicious
    suspicious=$(ss -tulnp 2>/dev/null | grep -cE ":22[0-9]{2}|:31[0-9]{2}|:44[0-9]{2}" || true)
    [[ ${suspicious:-0} -gt 0 ]] && echo "⚠️  Found $suspicious potentially suspicious listening port(s)"
  elif command -v netstat >/dev/null 2>&1; then
    local suspicious
    suspicious=$(netstat -tulnp 2>/dev/null | grep -cE ":22[0-9]{2}|:31[0-9]{2}|:44[0-9]{2}" || true)
    [[ ${suspicious:-0} -gt 0 ]] && echo "⚠️  Found $suspicious potentially suspicious listening port(s)"
  fi

  [[ -f /etc/apt/apt.conf.d/20auto-upgrades ]] && grep -q 'APT::Periodic::Unattended-Upgrade "1"' /etc/apt/apt.conf.d/20auto-upgrades 2>/dev/null && echo "✅ Unattended security upgrades enabled"

  return $warnings
}

run_security_audit() {
  local failures=0
  export NAN_DOC_TS="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

  echo "🔐 Running comprehensive security audit..."
  echo "Timestamp: $NAN_DOC_TS" >"$SECURITY_LOG"

  {
    echo ""
    check_file_permissions; [[ $? -gt 0 ]] && ((failures++))
    echo ""
    scan_for_secrets; [[ $? -gt 0 ]] && ((failures++))
    echo ""
    check_system_security; [[ $? -gt 0 ]] && ((failures++))
  } | tee -a "$SECURITY_LOG"

  echo ""
  echo "📄 Security audit completed. Log saved to: $SECURITY_LOG"
  [[ $failures -gt 0 ]] && echo "❌ $failures section(s) with issues"
  return $failures
}

run_security_audit_json() {
  local failures=0
  export NAN_DOC_TS="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

  local perm_out sec_out sys_out
  perm_out=$(check_file_permissions 2>&1); [[ $? -gt 0 ]] && ((failures++))
  sec_out=$(scan_for_secrets 2>&1); [[ $? -gt 0 ]] && ((failures++))
  sys_out=$(check_system_security 2>&1); [[ $? -gt 0 ]] && ((failures++))

  python3 -c "
import json, os
ts = os.environ.get('NAN_DOC_TS', '')
print(json.dumps({
  'timestamp': ts,
  'total_checks': 3,
  'failures': $failures,
  'compliant': $failures == 0,
  'permissions': {'output': '''$(_jstr "$perm_out")''', 'ok': True},
  'secrets': {'output': '''$(_jstr "$sec_out")''', 'ok': $failures == 0},
  'system': {'output': '''$(_jstr "$sys_out")''', 'ok': True},
}))
" 2>/dev/null && return $failures

  echo "{\"timestamp\":\"$NAN_DOC_TS\",\"error\":\"python3 required for full JSON output\"}"
  return $failures
}

_jstr() {
  python3 -c "import sys,json; print(json.dumps(sys.stdin.read()))" 2>/dev/null
}

apply_security_fixes() {
  echo "🔧 Applying security fixes..."

  if [[ -d "$HOME/.ssh" ]]; then
    chmod 700 "$HOME/.ssh" && echo "✅ Fixed SSH directory permissions (700)"
    find "$HOME/.ssh" -type f \( -name "id_*" -o -name "*_rsa" -o -name "*_ed25519" -o -name "*_ecdsa" \) ! -name "*.pub" -exec chmod 600 {} \; && echo "✅ Fixed SSH private key permissions (600)"
    [[ -f "$HOME/.ssh/config" ]] && chmod 600 "$HOME/.ssh/config" && echo "✅ Fixed SSH config permissions (600)"
    find "$HOME/.ssh" -name "*.pub" -exec chmod 644 {} \; && echo "✅ Fixed SSH public key permissions (644)"
  fi

  local cred_dir="$HOME/.config/private_credentials"
  if [[ -d $cred_dir ]]; then
    find "$cred_dir" -type f -exec chmod 600 {} \; && chmod 700 "$cred_dir" && echo "✅ Fixed credential file permissions"
  fi

  find "$HOME/.local/bin" -name "executable_dots-*" -exec chmod 755 {} \; && echo "✅ Fixed script permissions"
  find "$HOME" -maxdepth 3 -type f \( -name "*.key" -o -name "*.pem" -o -name "*.p12" -o -name "*.pfx" \) -exec chmod 600 {} \; 2>/dev/null && echo "✅ Fixed sensitive file permissions"

  local home_perms
  home_perms=$(stat -c %a "$HOME" 2>/dev/null)
  if [[ ${home_perms: -1} -gt "5" ]]; then
    chmod o-rwx "$HOME" && echo "✅ Removed world permissions from home directory"
  fi

  if [[ -f "$HOME/.zsh_history" ]]; then
    local before
    before=$(wc -l <"$HOME/.zsh_history")
    grep -vEi "^[^#]*(password|token|secret|key).*=" "$HOME/.zsh_history" >"${HOME}.zsh_history.tmp" && mv "${HOME}.zsh_history.tmp" "$HOME/.zsh_history" && echo "✅ Cleaned sensitive entries from zsh history"
  fi

  if [[ -f "$HOME/.bash_history" ]]; then
    grep -vEi "^[^#]*(password|token|secret|key).*=" "$HOME/.bash_history" >"${HOME}.bash_history.tmp" && mv "${HOME}.bash_history.tmp" "$HOME/.bash_history" && echo "✅ Cleaned sensitive entries from bash history"
  fi

  echo ""
  echo "🔒 Security fixes applied."
  echo "⚠️  Review the cleaned history files to ensure legitimate content wasn't removed."
}

generate_security_report() {
  local report_file="$HOME/.cache/dots/security_report_$(date +%Y%m%d).md"

  {
    echo "# dots-security-audit Report"
    echo ""
    echo "_Generated: $(date)_"
    echo ""
    echo "## File Permissions"
    echo ""
    check_file_permissions
    echo ""
    echo "## Secrets Scan"
    echo ""
    scan_for_secrets
    echo ""
    echo "## System Security"
    echo ""
    check_system_security
    echo ""
    echo "## Recommendations"
    echo ""
    echo "### High Priority"
    echo "- Ensure all SSH keys have 600 permissions"
    echo "- Review any files flagged above for hardcoded secrets"
    echo "- Enable firewall if not already active"
    echo ""
    echo "### Medium Priority"
    echo "- Set up automatic security updates"
    echo "- Review SSH configuration for hardening"
    echo "- Run monthly security audits"
    echo ""
    echo "### Security Checklist"
    echo "- [ ] SSH keys properly secured"
    echo "- [ ] No plain-text secrets in config files"
    echo "- [ ] Firewall configured"
    echo "- [ ] Automatic updates enabled"
    echo ""
    echo "## Next Steps"
    echo ""
    echo "Run \`dots security-audit --fix\` to apply permission fixes and scrub shell history."
  } >"$report_file"

  echo "📋 Security report generated: $report_file"
}

# Main execution logic
if [[ -n ${json} ]]; then
  run_security_audit_json
elif [[ -n ${audit} ]]; then
  run_security_audit
elif [[ -n ${fix} ]]; then
  apply_security_fixes
elif [[ -n ${report} ]]; then
  generate_security_report
elif [[ -n ${permissions} ]]; then
  check_file_permissions
elif [[ -n ${secrets} ]]; then
  scan_for_secrets
elif [[ -n ${system} ]]; then
  check_system_security
else
  run_security_audit
fi
