#!/usr/bin/env bash

## Copyright (C) 2019-2025 Ulises Jeremias Cornejo Fandos
## Licensed under MIT.
##
## dots-hyprlock-theme: Generate hyprlock color overrides from the current
## smart-colors M3 palette (scheme.json).
##
## Reads ~/.cache/dots/smart-colors/scheme.json and writes a hyprlock-compatible
## source file to ~/.cache/dots/smart-colors/colors-hyprlock.conf, which is
## included by ~/.config/hypr/hyprlock.conf via a `source =` directive.
##
## Usage:
##     dots-hyprlock-theme [--wallpaper /path/to/image]

set -euo pipefail

if [[ -f "$HOME/.local/lib/dots/wallpaper-resolver.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.local/lib/dots/wallpaper-resolver.sh"
fi

SMART_COLORS_DIR="${HOME}/.cache/dots/smart-colors"
SCHEME_FILE="${SMART_COLORS_DIR}/scheme.json"
OUTPUT_FILE="${SMART_COLORS_DIR}/colors-hyprlock.conf"
WALLPAPER_CACHE="${SMART_COLORS_DIR}/wallpaper"
DOTS_WALLPAPER_POINTER="${DOTS_WALLPAPER_POINTER_FILE:-${DOTS_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/dots}/wallpaper/path}"

# ── helpers ──────────────────────────────────────────────────────────────────

hex_to_hyprlock_rgba() {
  # Convert a 6-char hex (#rrggbb) + optional alpha (0-255 as 2-hex) to
  # hyprlock RGBA format: rrggbbaa (no #, always 8 chars)
  local hex="${1#\#}"
  local alpha="${2:-ff}"
  printf '%s%s\n' "$hex" "$alpha"
}

# ── parse scheme.json ─────────────────────────────────────────────────────────

if [[ ! -f $SCHEME_FILE ]]; then
  echo "dots-hyprlock-theme: scheme.json not found at $SCHEME_FILE — run dots-color-scheme first." >&2
  exit 1
fi

read_colour() {
  python3 - "$SCHEME_FILE" "$1" <<'PY'
import json, pathlib, sys
data = json.loads(pathlib.Path(sys.argv[1]).read_text())
key = sys.argv[2]
colours = data.get("colours", {})
val = colours.get(key, "")
print(val if val else "")
PY
}

is_light_mode() {
  python3 - "$SCHEME_FILE" <<'PY'
import json, pathlib, sys
data = json.loads(pathlib.Path(sys.argv[1]).read_text())
print("true" if data.get("mode", "dark") == "light" else "false")
PY
}

# Extract key palette colours
primary="$(read_colour primary)"
surface="$(read_colour surface)"
on_surface="$(read_colour onSurface)"
background="$(read_colour background)"
on_surface_variant="$(read_colour onSurfaceVariant)"
outline="$(read_colour outline)"
secondary="$(read_colour secondary)"
error="$(read_colour error)"
light_mode="$(is_light_mode)"

# Resolve wallpaper path
wallpaper=""
if [[ $# -ge 1 && -n ${1:-} ]]; then
  wallpaper="$1"
elif [[ -f $WALLPAPER_CACHE ]]; then
  wallpaper="$(cat "$WALLPAPER_CACHE")"
elif [[ -f $DOTS_WALLPAPER_POINTER ]]; then
  wallpaper="$(cat "$DOTS_WALLPAPER_POINTER")"
fi

# ── generate hyprlock colour override file ────────────────────────────────────

mkdir -p "$SMART_COLORS_DIR"

# Build RGBA values for hyprlock (RRGGBBAA format, no #)
bg_rgba="$(hex_to_hyprlock_rgba "${background:-191114}" "ff")"
surface_rgba="$(hex_to_hyprlock_rgba "${surface:-191114}" "aa")"
primary_rgba="$(hex_to_hyprlock_rgba "${primary:-ffb0ca}" "ff")"
on_surface_rgba="$(hex_to_hyprlock_rgba "${on_surface:-efdfe2}" "ff")"
on_surface_variant_rgba="$(hex_to_hyprlock_rgba "${on_surface_variant:-d5c2c6}" "cc")"
outline_rgba="$(hex_to_hyprlock_rgba "${outline:-9e8c91}" "88")"
secondary_rgba="$(hex_to_hyprlock_rgba "${secondary:-e2bdc7}" "ff")"
input_inner_rgba="$(hex_to_hyprlock_rgba "${surface:-191114}" "bb")"

cat >"$OUTPUT_FILE" <<EOF
# ============================================================================
# hyprlock smart-color overrides
# Auto-generated by dots-hyprlock-theme — do not edit manually.
# Source: $SCHEME_FILE
# ============================================================================

background {
    monitor =
    $(if [[ -n $wallpaper && -f $wallpaper ]]; then
  echo "path = $wallpaper"
else
  echo "color = 0xff${bg_rgba}"
fi)
    blur_passes = 3
    blur_size = 6
    noise = 0.012
    contrast = 0.9
    brightness = $(if [[ $light_mode == "true" ]]; then echo "1.1"; else echo "0.8"; fi)
    vibrancy = 0.15
    vibrancy_darkness = 0.0
}

input-field {
    monitor =
    size = 300, 60
    outline_thickness = 2
    dots_spacing = 0.35
    dots_center = true
    dots_rounding = -1
    fade_on_empty = true
    placeholder_text = <span foreground="##${on_surface_variant_rgba}">  Enter Password</span>
    font_color = rgb(${on_surface:-efdfe2})
    inner_color = rgba(${input_inner_rgba})
    outer_color = rgba(${outline_rgba})
    check_color = rgb(${primary:-ffb0ca})
    fail_color = rgba(${error:-ffb4ab}bb)
    fail_text = <i>$FAIL_REASON</i>
    fail_timeout = 2000
    rounding = 12
    shadow_passes = 3
    shadow_size = 8
    shadow_color = rgba(00000060)
}

label {
    monitor =
    text = \$TIME12
    text_align = center
    color = rgba(${on_surface_rgba})
    font_size = 56
    font_family = Rubik 300
    position = 0, 160
    halign = center
    valign = center
    shadow_passes = 3
    shadow_size = 6
    shadow_color = rgba(00000088)
}

label {
    monitor =
    text = \$DATE
    text_align = center
    color = rgba(${on_surface_variant_rgba})
    font_size = 14
    font_family = Rubik
    position = 0, 80
    halign = center
    valign = center
}

label {
    monitor =
    text =  \$USER
    text_align = center
    color = rgba(${secondary_rgba})
    font_size = 13
    font_family = Rubik
    position = 0, -80
    halign = center
    valign = center
}
EOF

echo "dots-hyprlock-theme: wrote color overrides to $OUTPUT_FILE"
