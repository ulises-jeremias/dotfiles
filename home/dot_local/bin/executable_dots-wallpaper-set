#!/usr/bin/env bash

## Copyright (C) 2019-2025 Ulises Jeremias Cornejo Fandos
## Licensed under MIT.
##
## Unified wallpaper entrypoint for Quickshell and scripts.
## wpgtk is optional (opt-in via having `wpg` succeed); pywal + state pointer are canonical.
##
set -euo pipefail

source ~/.local/lib/dots/easy-options/easyoptions.sh || exit 1

if [[ -f "$HOME/.local/lib/dots/wallpaper-resolver.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.local/lib/dots/wallpaper-resolver.sh"
fi

# Quickshell launcher calls this script; dirs must exist without chezmoi or manual mkdir.
mkdir -p "$(dirname "${DOTS_WALLPAPER_POINTER_FILE:-${XDG_STATE_HOME:-$HOME/.local/state}/dots/wallpaper/path}")" \
  "${HOME}/.cache/dots/smart-colors" 2>/dev/null || true

show_error() {
  echo "❌ $1" >&2
}

show_info() {
  echo "ℹ️ $1"
}

# One-time migration: older installs used ~/.cache/dots/wallpaper/path only.
migrate_legacy_pointer_if_needed() {
  local state_p="${DOTS_WALLPAPER_POINTER_FILE:-}"
  local legacy_p="${DOTS_LEGACY_WALLPAPER_POINTER:-}"
  [[ -n $state_p && -n $legacy_p ]] || return 0
  [[ -f $state_p ]] && return 0
  [[ -f $legacy_p ]] || return 0
  mkdir -p "$(dirname "$state_p")"
  cp -a "$legacy_p" "$state_p"
}

# Persistent state pointer + smart-colors input copy (under cache).
sync_wallpaper_state() {
  migrate_legacy_pointer_if_needed
  mkdir -p "$(dirname "${DOTS_WALLPAPER_POINTER_FILE}")" "$HOME/.cache/dots/smart-colors"
  printf '%s\n' "$WALLPAPER_PATH" >"${DOTS_WALLPAPER_POINTER_FILE}"
  printf '%s\n' "$WALLPAPER_PATH" >"$HOME/.cache/dots/smart-colors/wallpaper"
}

usage() {
  echo "Usage: $0 <wallpaper_path>"
}

if [[ ${help:-} == "yes" || ${h:-} == "yes" ]]; then
  usage
  exit 0
fi

WALLPAPER_INPUT="${1:-}"
if [[ -z $WALLPAPER_INPUT ]]; then
  usage
  exit 1
fi

WALLPAPER_PATH="$WALLPAPER_INPUT"
if declare -f dots_current_wallpaper >/dev/null 2>&1; then
  WALLPAPER_PATH="$(dots_current_wallpaper "$WALLPAPER_INPUT" 2>/dev/null || true)"
fi
if [[ -z ${WALLPAPER_PATH:-} || ! -f $WALLPAPER_PATH ]]; then
  show_error "Wallpaper file not found: $WALLPAPER_INPUT"
  exit 1
fi

if command -v wpg >/dev/null 2>&1; then
  if wpg -s "$WALLPAPER_PATH" >/dev/null 2>&1; then
    show_info "Wallpaper set via wpgtk"
    if declare -f dots_current_wallpaper >/dev/null 2>&1; then
      resolved="$(dots_current_wallpaper 2>/dev/null || true)"
      if [[ -n ${resolved:-} && -f $resolved ]]; then
        WALLPAPER_PATH="$resolved"
      fi
    fi
    sync_wallpaper_state
    if command -v dots-smart-colors >/dev/null 2>&1; then
      dots-smart-colors --generate --m3 >/dev/null 2>&1 || true
    fi
    if pgrep -x quickshell >/dev/null 2>&1 && command -v dots-quickshell >/dev/null 2>&1; then
      dots-quickshell ipc colours reload >/dev/null 2>&1 || true
    fi
    exit 0
  fi
  show_info "wpgtk failed, using pywal pipeline"
fi

# Core pipeline (no wpg): pywal + persistent pointer + smart colors.
if command -v wal >/dev/null 2>&1; then
  wal -i "$WALLPAPER_PATH" -q 2>/dev/null || true
fi

sync_wallpaper_state

if command -v dots-smart-colors >/dev/null 2>&1; then
  dots-smart-colors --generate --m3 >/dev/null 2>&1 || true
fi

if pgrep -x quickshell >/dev/null 2>&1 && command -v dots-quickshell >/dev/null 2>&1; then
  dots-quickshell ipc colours reload >/dev/null 2>&1 || true
fi

show_info "Wallpaper state set (pywal + state pointer)"
