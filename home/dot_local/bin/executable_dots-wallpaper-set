#!/usr/bin/env bash

## Copyright (C) 2019-2025 Ulises Jeremias Cornejo Fandos
## Licensed under MIT.
##
## Unified wallpaper entrypoint — IPC stub for Quickshell.
## When Quickshell is running, delegates to Rice.setWallpaper via IPC.
## Falls back to direct wal + state pointer write when QS is not running.
##
set -euo pipefail

WALLPAPER_INPUT="${1:-}"
if [[ -z $WALLPAPER_INPUT ]]; then
  echo "Usage: $0 <wallpaper_path>" >&2
  exit 1
fi

WALLPAPER_PATH="$(readlink -f "$WALLPAPER_INPUT" 2>/dev/null || true)"
if [[ -z ${WALLPAPER_PATH:-} || ! -f $WALLPAPER_PATH ]]; then
  echo "Error: wallpaper file not found: $WALLPAPER_INPUT" >&2
  exit 1
fi

if pgrep -x quickshell >/dev/null 2>&1; then
  quickshell ipc call rice setWallpaper "$WALLPAPER_PATH"
  exit 0
fi

# Fallback: direct pywal + state pointer
if command -v wal >/dev/null 2>&1; then
  wal -i "$WALLPAPER_PATH" -q 2>/dev/null || true
fi

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/dots/wallpaper"
mkdir -p "$STATE_DIR"
printf '%s\n' "$WALLPAPER_PATH" >"$STATE_DIR/path"
printf '%s\n' "$WALLPAPER_PATH" >"${XDG_CACHE_HOME:-$HOME/.cache}/dots/smart-colors/wallpaper" 2>/dev/null || true
