#!/usr/bin/env bash

## Copyright (C) 2019-2025 Ulises Jeremias Cornejo Fandos
## Licensed under MIT.
##
## Wal reload — IPC stub for Quickshell.
## When Quickshell is running, delegates to Rice.reload() via IPC which runs
## wal -R, regenerates M3 scheme, reloads Hyprland, kitty, and GTK in-process.
## Falls back to direct wal -R when QS is not running.
##
set -euo pipefail

if pgrep -x quickshell >/dev/null 2>&1; then
  quickshell ipc call rice reload
  exit 0
fi

# Fallback: direct wal reload
if command -v wal >/dev/null 2>&1; then
  wal -R -q 2>/dev/null || true
fi

# Fallback: regenerate M3 scheme if possible
M3_SCRIPT="${HOME}/.local/lib/dots/generate-m3-colors.py"
SCHEME_JSON="${XDG_CACHE_HOME:-$HOME/.cache}/dots/smart-colors/scheme.json"
WALL_POINTER="${XDG_STATE_HOME:-$HOME/.local/state}/dots/wallpaper/path"

if [[ -f $WALL_POINTER && -f $M3_SCRIPT ]] && command -v python3 >/dev/null 2>&1; then
  wallpaper="$(cat "$WALL_POINTER" 2>/dev/null || true)"
  if [[ -n ${wallpaper:-} && -f $wallpaper ]]; then
    python3 "$M3_SCRIPT" --image "$wallpaper" --output "$SCHEME_JSON" 2>/dev/null || true
  fi
fi
