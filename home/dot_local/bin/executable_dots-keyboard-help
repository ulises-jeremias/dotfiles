#!/usr/bin/env bash

## Copyright (C) 2019-2025 Ulises Jeremias Cornejo Fandos
## Licensed under MIT.
##
## Interactive keyboard shortcuts help overlay for Hyprland
## Displays all available keybindings in a searchable picker
##
## Check full documentation at: https://github.com/ulises-jeremias/dotfiles/wiki
##
## Usage:
##     @script.name [OPTIONS]
##
## Options:
##     -h, --help              Show this help message
##         --category=CAT      Filter by category (apps|window|workspace|media|system)
##         --search=TERM       Search for specific keybinding

set -euo pipefail

source ~/.local/lib/dots/easy-options/easyoptions.sh || exit

readonly KEYBINDINGS_FILE="${HOME}/.config/hypr/hyprland.conf.d/keybindings.conf"

if [[ ${DOTS_BYPASS_QUICKSHELL:-0} != 1 ]] && pgrep -x quickshell >/dev/null 2>&1; then
  dots-settings-gui --pane=system menu
  exit 0
fi

parse_keybindings() {
  if command -v hyprctl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    hyprctl binds -j 2>/dev/null | jq -r '
      def has_mod($bit): (((.modmask // 0) / $bit | floor) % 2) == 1;
      def mod_names:
        [if has_mod(64) then "SUPER" else empty end,
         if has_mod(8) then "ALT" else empty end,
         if has_mod(4) then "CTRL" else empty end,
         if has_mod(1) then "SHIFT" else empty end]
        | join(" + ");
      def category:
        if ((.description // "") | startswith("[")) then
          (.description | split("]")[0] | ltrimstr("["))
        elif (.key | startswith("XF86Audio")) or (.key | startswith("XF86MonBrightness")) then
          "Media Keys"
        elif (.key == "Print") or ((.arg // "") | contains("screenshooter")) then
          "Screenshots"
        elif ((.arg // "") | test("TerminalEmulator|dots-launcher|dots-clipboard|FileManager|dots-yazi|WebBrowser|dashboard|dots-power-menu|lock lock|dots-keyboard-help|gaps-interactive")) then
          "Essential Applications"
        elif ((.dispatcher // "") | test("killactive|togglefloating|fullscreen|pin|focuscurrentorlast|centerwindow|changegroupactive|togglegroup|lockactivegroup")) or ((.arg // "") | test("fullscreen|focuscurrentorlast|centerwindow|changegroupactive|togglegroup|lockactivegroup")) then
          "Window Management"
        elif ((.dispatcher // "") | test("movefocus|movewindow|resizeactive|submap")) or ((.arg // "") | test("layoutmsg|colresize|promote|togglefit|fit active|fit visible")) then
          "Window Management"
        elif ((.dispatcher // "") | test("workspace|movetoworkspace|movetoworkspacesilent|togglespecialworkspace")) or ((.arg // "") | test("workspace|movetoworkspacesilent|special:magic")) then
          "Workspace Navigation"
        elif ((.arg // "") | test("hyprctl reload|bar toggle")) or ((.dispatcher // "") == "exit") then
          "System Control"
        else
          "Uncategorized"
        end;
      map(. + {category: category, mod_text: mod_names})[]
      | "[" + .category + "] " +
        (if .mod_text != "" then .mod_text + " + " else "" end) +
        .key + " -> " + .dispatcher +
        (if (.arg // "") != "" then ": " + .arg else "" end)
    ' 2>/dev/null && return 0
  fi

  if [[ -f ${HOME}/.config/hypr/hyprland.lua ]]; then
    echo "[ERROR] jq is required to read Lua-era Hyprland keybindings from hyprctl binds -j" >&2
    return 1
  fi

  [[ -f $KEYBINDINGS_FILE ]] || return 1

  awk '
    /^# =+ .* =+$/ {
      cat = $0
      gsub(/^# =+ /, "", cat)
      gsub(/ =+$/, "", cat)
      next
    }
    /^bind[eml]* = / {
      line = $0
      sub(/^bind[eml]* = /, "", line)
      n = split(line, a, /,/)
      if (n >= 3) {
        mods = a[1]
        key = a[2]
        action = substr(line, index(line, a[3]))
        gsub(/^ +| +$/, "", mods)
        gsub(/^ +| +$/, "", key)
        gsub(/^ +| +$/, "", action)
        gsub(/\$mainMod/, "SUPER", mods)
        gsub(/ +/, " + ", mods)
        if (cat != "") {
          printf("[%s] %s%s%s -> %s\n", cat, mods, mods == "" ? "" : " + ", key, action)
        } else {
          printf("%s%s%s -> %s\n", mods, mods == "" ? "" : " + ", key, action)
        }
      }
    }
  ' "$KEYBINDINGS_FILE"
}

show_help() {
  local content
  content="$(parse_keybindings)" || {
    echo "[ERROR] Could not retrieve keybindings. Is Hyprland running?" >&2
    exit 1
  }

  if [[ -n ${search:-} ]]; then
    content="$(printf '%s\n' "$content" | awk -v s="${search,,}" 'tolower($0) ~ s')"
  fi
  if [[ -n ${category:-} ]]; then
    local category_filter
    case "${category,,}" in
      apps | app | applications) category_filter="essential applications" ;;
      window | windows) category_filter="window" ;;
      workspace | workspaces) category_filter="workspace" ;;
      media) category_filter="media" ;;
      system) category_filter="system" ;;
      screenshots | screenshot) category_filter="screenshots" ;;
      *) category_filter="${category,,}" ;;
    esac
    content="$(printf '%s\n' "$content" | awk -v c="$category_filter" 'tolower($0) ~ "\\[" c')"
  fi

  [[ -z ${content:-} ]] && {
    echo "[WARN] No keybindings found" >&2
    exit 1
  }

  printf '%s\n' "$content" | less
}

main() {
  show_help
}

main "$@"
