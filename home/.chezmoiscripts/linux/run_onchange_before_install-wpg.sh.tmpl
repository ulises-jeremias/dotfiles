{{ if and (not .ephemeral) (not .headless) -}}

{{ if eq .osid "linux-arch" -}}
#!/usr/bin/env bash

yay -S --noconfirm --needed \
    feh \
    python-pywal \
    sassc

if ! uv tool list | grep -q "^wpgtk"; then
    uv tool install wpgtk --with pygobject
else
    uv tool upgrade wpgtk
fi
